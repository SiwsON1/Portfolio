{
  "name": "produkcja-hero",
  "version": "1.0.0",
  "description": "Remotion compositor for Marcin Siwonia portfolio hero film",
  "scripts": {
    "preview": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts HeroFilm output/hero.mp4 && remotion render src/index.ts HeroFilm output/hero.webm --codec=vp9",
    "render:mp4": "remotion render src/index.ts HeroFilm output/hero.mp4",
    "render:webm": "remotion render src/index.ts HeroFilm output/hero.webm --codec=vp9"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.250",
    "@remotion/media-utils": "^4.0.250",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.250"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.3"
  }
}
